<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>CHMGenerator</AssemblyName>
    <RootNamespace>CHMGenerator.WPF</RootNamespace>
    <Version>2.0.0</Version>
    <Company>CHMGenerator</Company>
    <Product>CHM Generator WPF</Product>
    <Description>可视化 CHM 帮助文档生成器</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- Word 转 HTML：OpenXmlPowerTools 才是正确方向（HtmlToOpenXml 是 HTML→Word，方向反了） -->
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.5.1" />
    <PackageReference Include="Codeuctivity.OpenXmlPowerTools" Version="9.0.493" />

    <!-- MVVM -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />

    <!-- 系统编码支持（GB2312） -->
    <PackageReference Include="System.Text.Encoding.CodePages" Version="8.0.0" />
  </ItemGroup>

</Project>
