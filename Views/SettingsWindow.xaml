<Window x:Class="CHMGenerator.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="工具配置" Height="350" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBrush}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Python 转换器配置 -->
        <GroupBox Grid.Row="0" Header="Word 文档转换工具" Padding="15">
            <StackPanel>
                <CheckBox x:Name="UsePythonCheckBox"
                          Content="使用 Python doc2html 转换 Word 文件（推荐）"
                          Foreground="{DynamicResource TextBrush}"
                          Margin="0,0,0,10"
                          Checked="UpdateStatus"
                          Unchecked="UpdateStatus"/>

                <TextBlock Text="Python 工具目录路径："
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,5"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="PythonPathTextBox"
                             Grid.Column="0"
                             Padding="6,4"
                             TextChanged="PythonPath_TextChanged"
                             IsEnabled="{Binding IsChecked, ElementName=UsePythonCheckBox}"/>

                    <Button Grid.Column="2"
                            Content="浏览..."
                            Padding="15,4"
                            Click="BrowsePythonPath_Click"
                            IsEnabled="{Binding IsChecked, ElementName=UsePythonCheckBox}"/>
                </Grid>

                <TextBlock x:Name="PythonStatusText"
                           Text="状态：未启用"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,8,0,0"
                           FontSize="11"/>
            </StackPanel>
        </GroupBox>

        <!-- 说明 -->
        <TextBlock Grid.Row="2"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextBrush}"
                   Opacity="0.7"
                   FontSize="11">
            <Run Text="说明："/>
            <LineBreak/>
            <Run Text="• 不勾选：使用程序内置的转换器（OpenXmlPowerTools）"/>
            <LineBreak/>
            <Run Text="• 勾选：使用 Python doc2html（生成更简洁的 HTML，兼容性更好）"/>
            <LineBreak/>
            <Run Text="• 默认路径：{项目目录}\ExternalTools"/>
            <LineBreak/>
            <Run Text="• Python 工具目录应包含：DocToCHM.py、hyperlink_processor.py、resource/"/>
            <LineBreak/>
            <Run Text="• 需要 Python 环境：pip install python-docx pillow lxml"/>
        </TextBlock>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="保存"
                    Padding="20,6"
                    Margin="0,0,10,0"
                    Click="Save_Click"/>
            <Button Content="取消"
                    Padding="20,6"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
